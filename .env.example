# Copy this file to `.env` and fill in the values from your Supabase project.
# (Project Settings -> API in the Supabase dashboard.)

# --- Required: Supabase client (frontend) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# --- Optional: canonical site origin (no trailing slash) ---
# Used for structured data / SEO and by scripts/generate-sitemap.mjs.
# Defaults to https://example.com when unset.
VITE_SITE_URL=https://example.com

# --- Optional: prefill the admin login email field ---
VITE_ADMIN_LOGIN_EMAIL=admin@example.com

# --- Optional: storage backup script (scripts/backup-supabase-storage.mjs) ---
# Server-side only. Never expose the service role key in the frontend.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_STORAGE_BUCKETS=post-images,site-assets
